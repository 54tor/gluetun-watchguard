# gluetun-watchguard configuration (all values are optional; defaults shown).
# Copy to .env and adjust. Booleans accept: 1/true/yes/on.

# --- General ---
LOG_LEVEL=INFO
CHECK_INTERVAL=30           # seconds between watch ticks

# --- Feature toggles ---
ENABLE_PORT_SYNC=true
ENABLE_HEALTHCHECK=true
ENABLE_PORT_CHECK=true      # verify the forwarded port is actually reachable
ENABLE_DOCKER_ACTION=true

# --- gluetun control server ---
GLUETUN_CONTROL_URL=http://gluetun:8000
# GLUETUN_API_KEY=            # X-API-Key header, if the control server needs it
# GLUETUN_AUTH_USERNAME=      # or HTTP basic auth
# GLUETUN_AUTH_PASSWORD=

# --- Torrent client (qbittorrent | transmission | rutorrent) ---
TORRENT_CLIENT=qbittorrent
CLIENT_URL=http://gluetun:8080
CLIENT_USERNAME=admin
CLIENT_PASSWORD=adminadmin
# RUTORRENT_RPC_PATH=/plugins/httprpc/action.php   # ruTorrent only

# --- Docker recovery action ---
DOCKER_SOCKET=/var/run/docker.sock
# Target container to act on. Use ONE of the following:
#   GLUETUN_CONTAINER  explicit name/id (highest precedence)
#   GLUETUN_SERVICE    compose service name, resolved via labels (same project)
GLUETUN_CONTAINER=gluetun
# GLUETUN_SERVICE=gluetun
# COMPOSE_PROJECT=            # auto-detected in-container; required for host/dev runs (make run)
DOCKER_ACTION=restart       # restart | stop | none
PORT_CHECK_RECOVERY=false   # let a sustained closed forwarded port trigger recovery

# --- Anti-flap / debounce (prevents restart storms on slow disks) ---
FAILURE_THRESHOLD=3         # consecutive failed checks before acting
RESTART_COOLDOWN=300        # min seconds between docker actions
STARTUP_GRACE=60            # seconds to ignore failures after start / action
HTTP_TIMEOUT=10             # seconds for API calls
